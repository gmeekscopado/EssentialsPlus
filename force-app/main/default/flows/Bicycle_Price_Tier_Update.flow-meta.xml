            </value>
        </assignmentItems>
    </assignments>
    <assignments>
        <name>Set_Tier_2</name>
        <label>Set Tier 2</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <assignmentItems>
            <assignToReference>$Record.Price_Tier__c</assignToReference>
